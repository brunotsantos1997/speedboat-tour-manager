п»їrules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =================================================================
    // FUNГѓвЂЎГѓвЂўES AUXILIARES
    // =================================================================
    
    // Verifica se o usuГѓВЎrio estГѓВЎ autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // ObtГѓВ©m dados do perfil do usuГѓВЎrio
    function getUserData() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }
    
    // Verifica se o usuГѓВЎrio estГѓВЎ aprovado
    function isApproved() {
      return isAuthenticated() && getUserData().status == 'APPROVED';
    }
    
    // Verifica se o usuГѓВЎrio tem permissГѓВЈo de staff
    function hasStaffPermission(allowAdmin) {
      return isApproved() && (
        getUserData().role == 'OWNER' ||
        getUserData().role == 'SUPER_ADMIN' ||
        (allowAdmin && getUserData().role == 'ADMIN')
      );
    }
    
    // Verifica se o usuГѓВЎrio pode gerenciar usuГѓВЎrios
    function canManageUsers() {
      return hasStaffPermission(true);
    }
    
    // Verifica hierarquia para alteraГѓВ§ГѓВµes de status/role
    function canModifyTargetUser(targetRole) {
      let currentUser = getUserData();
      
      // OWNER pode modificar qualquer um
      if (currentUser.role == 'OWNER') return true;
      
      // SUPER_ADMIN pode modificar ADMIN e SELLER
      if (currentUser.role == 'SUPER_ADMIN') {
        return targetRole == 'ADMIN' || targetRole == 'SELLER';
      }
      
      // ADMIN pode modificar apenas SELLER
      if (currentUser.role == 'ADMIN') {
        return targetRole == 'SELLER';
      }
      
      // SELLER nГѓВЈo pode modificar ninguГѓВ©m
      return false;
    }
    
    // Verifica se o usuГѓВЎrio pode acessar eventos
    function canAccessEvents() {
      return isApproved();
    }
    
    // Verifica se o usuГѓВЎrio pode gerenciar finanГѓВ§as
    function canManageFinance() {
      return hasStaffPermission(true);
    }
    
    // Verifica se o usuГѓВЎrio pode gerenciar configuraГѓВ§ГѓВµes
    function canManageSettings() {
      return getUserData().role == 'OWNER' || getUserData().role == 'SUPER_ADMIN';
    }
    
    // Verifica se o usuГѓВЎrio ГѓВ© dono do recurso
    function isOwner(resource) {
      return resource.data.createdByUserId == request.auth.uid;
    }
    
    // Valida campos obrigatГѓВіrios para eventos
    function validateEventFields(data) {
      return data.keys().hasAll([
        'date', 'startTime', 'endTime', 'status', 
        'boat', 'client', 'total', 'createdByUserId'
      ]);
    }
    
    // Valida campos obrigatГѓВіrios para usuГѓВЎrios
    function validateUserFields(data) {
      return data.keys().hasAll([
        'name', 'email', 'status', 'role'
      ]);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: profiles
    // =================================================================
    
    match /profiles/{userId} {
      // Leitura: prГѓВіprio usuГѓВЎrio ou staff
      allow read: if (isAuthenticated() && 
        (request.auth.uid == userId || hasStaffPermission(true)));
      
      // CriaГѓВ§ГѓВЈo: apenas prГѓВіprio usuГѓВЎrio
      allow create: if isAuthenticated() && 
        request.auth.uid == userId &&
        validateUserFields(request.resource.data) &&
        request.resource.data.keys().hasAll(['name', 'email']) &&
        request.resource.data.status == 'PENDING' &&
        request.resource.data.role in ['OWNER', 'SUPER_ADMIN', 'ADMIN', 'SELLER'];
      
      // AtualizaГѓВ§ГѓВЈo: prГѓВіprio usuГѓВЎrio (campos limitados) ou staff com validaГѓВ§ГѓВЈo hierГѓВЎrquica
      allow update: if isApproved() && (
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['role', 'status', 'commissionPercentage', 'email'])) ||
        (hasStaffPermission(true) && canModifyTargetUser(resource.data.role))
      );
      
      // ExclusГѓВЈo: apenas staff
      allow delete: if hasStaffPermission(true);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: events
    // =================================================================
    
    match /events/{eventId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if canAccessEvents();
      
      // CriaГѓВ§ГѓВЈo: usuГѓВЎrios aprovados
      allow create: if canAccessEvents() &&
        validateEventFields(request.resource.data) &&
        request.resource.data.createdByUserId == request.auth.uid &&
        request.resource.data.status in ['SCHEDULED', 'PRE_SCHEDULED'];
      
      // AtualizaГѓВ§ГѓВЈo: staff ou dono do evento
      allow update: if canAccessEvents() && 
        (hasStaffPermission(false) || isOwner(resource));
      
      // ExclusГѓВЈo: apenas staff
      allow delete: if hasStaffPermission(true);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: boats
    // =================================================================
    
    match /boats/{boatId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: staff
      allow create: if hasStaffPermission(false) &&
        request.resource.data.keys().hasAll(['name', 'capacity', 'pricePerHour']);
      
      // AtualizaГѓВ§ГѓВЈo: staff
      allow update: if hasStaffPermission(false);
      
      // ExclusГѓВЈo: apenas admin+
      allow delete: if hasStaffPermission(true);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: products
    // =================================================================
    
    match /products/{productId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: staff
      allow create: if hasStaffPermission(false) &&
        request.resource.data.keys().hasAll(['name', 'pricingType']);
      
      // AtualizaГѓВ§ГѓВЈo: staff
      allow update: if hasStaffPermission(false);
      
      // ExclusГѓВЈo: apenas admin+
      allow delete: if hasStaffPermission(true);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: clients
    // =================================================================
    
    match /clients/{clientId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: usuГѓВЎrios aprovados
      allow create: if isApproved() &&
        request.resource.data.keys().hasAll(['phone', 'name']);
      
      // AtualizaГѓВ§ГѓВЈo: staff
      allow update: if hasStaffPermission(false);
      
      // ExclusГѓВЈo: apenas admin+
      allow delete: if hasStaffPermission(true);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: payments
    // =================================================================
    
    match /payments/{paymentId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: usuГѓВЎrios aprovados
      allow create: if isApproved() &&
        request.resource.data.keys().hasAll(['eventId', 'amount', 'method', 'date']);
      
      // AtualizaГѓВ§ГѓВЈo: staff ou dono do evento relacionado
      allow update: if isApproved() && 
        (hasStaffPermission(false) || 
         get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.createdByUserId == request.auth.uid);
      
      // ExclusГѓВЈo: apenas admin+
      allow delete: if hasStaffPermission(true);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: expenses
    // =================================================================
    
    match /expenses/{expenseId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: usuГѓВЎrios aprovados
      allow create: if isApproved() &&
        request.resource.data.keys().hasAll(['amount', 'description', 'date', 'categoryId']);
      
      // AtualizaГѓВ§ГѓВЈo: staff ou dono da despesa
      allow update: if isApproved() && 
        (hasStaffPermission(false) || resource.data.createdByUserId == request.auth.uid);
      
      // ExclusГѓВЈo: staff ou dono
      allow delete: if isApproved() && 
        (hasStaffPermission(false) || resource.data.createdByUserId == request.auth.uid);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: expenseCategories
    // =================================================================
    
    match /expense_categories/{categoryId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: staff
      allow create: if hasStaffPermission(false) &&
        request.resource.data.keys().hasAll(['name']);
      
      // AtualizaГѓВ§ГѓВЈo: staff
      allow update: if hasStaffPermission(false);
      
      // ExclusГѓВЈo: apenas admin+
      allow delete: if hasStaffPermission(true);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: boardingLocations
    // =================================================================
    
    match /boarding_locations/{locationId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: staff
      allow create: if hasStaffPermission(false) &&
        request.resource.data.keys().hasAll(['name']);
      
      // AtualizaГѓВ§ГѓВЈo: staff
      allow update: if hasStaffPermission(false);
      
      // ExclusГѓВЈo: apenas admin+
      allow delete: if hasStaffPermission(true);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: tourTypes
    // =================================================================
    
    match /tour_types/{tourTypeId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: staff
      allow create: if hasStaffPermission(false) &&
        request.resource.data.keys().hasAll(['name', 'color']);
      
      // AtualizaГѓВ§ГѓВЈo: staff
      allow update: if hasStaffPermission(false);
      
      // ExclusГѓВЈo: apenas admin+
      allow delete: if hasStaffPermission(true);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: companyData
    // =================================================================
    
    match /company_data/{dataId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: apenas owner/super admin
      allow create: if canManageSettings();
      
      // AtualizaГѓВ§ГѓВЈo: apenas owner/super admin
      allow update: if canManageSettings();
      
      // ExclusГѓВЈo: apenas owner
      allow delete: if getUserData().role == 'OWNER';
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: voucherTerms
    // =================================================================
    
    match /voucher_terms/{termsId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: staff
      allow create: if hasStaffPermission(false);
      
      // AtualizaГѓВ§ГѓВЈo: staff
      allow update: if hasStaffPermission(false);
      
      // ExclusГѓВЈo: apenas admin+
      allow delete: if hasStaffPermission(true);
    }
    
    // =================================================================
    // COLEГѓвЂЎГѓЖ’O: voucherAppearance
    // =================================================================
    
    match /voucher_appearance/{appearanceId} {
      // Leitura: usuГѓВЎrios aprovados
      allow read: if isApproved();
      
      // CriaГѓВ§ГѓВЈo: staff
      allow create: if hasStaffPermission(false);
      
      // AtualizaГѓВ§ГѓВЈo: staff
      allow update: if hasStaffPermission(false);
      
      // ExclusГѓВЈo: apenas admin+
      allow delete: if hasStaffPermission(true);
    }

    // =================================================================
    // COLECAO: public_vouchers
    // =================================================================

    match /public_vouchers/{voucherId} {
      // Leitura publica para a rota de voucher
      allow read: if true;

      // Escrita apenas por usuarios aprovados do sistema
      allow create, update, delete: if isApproved();
    }
    

    // =================================================================
    // REGRA PADRГѓЖ’O (NEGAR TUDO)
    // =================================================================
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

